# ── 프로덕션 환경변수 예시 ────────────────────────────────────
# 이 파일을 복사해서 .env 로 만든 뒤 실제 값으로 교체하세요.
# .env 는 절대 git에 커밋하지 마세요.

# ── MariaDB ──────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=your-root-password-here
MYSQL_PASSWORD=your-db-password-here

# ── FastAPI ───────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열 (예: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Cloudflare Tunnel ─────────────────────────────────────────
# Cloudflare Dashboard → Zero Trust → Networks → Tunnels 에서 발급
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# ── GitHub (docker-compose.yml 에서 이미지 경로에 사용) ───────
# 예: username/license-system
GITHUB_REPOSITORY=your-github-username/license-system
